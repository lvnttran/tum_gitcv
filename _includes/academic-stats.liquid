{% assign papers = site.data.citations.papers %}
{% assign citation_counts = "" | split: "" %}
{% for p in papers %}
  {% assign citation_counts = citation_counts | push: p[1].citations %}
{% endfor %}
{% assign sorted = citation_counts | sort | reverse %}
{% assign total_citations = citation_counts | sum %}

{% assign h_index = 0 %}
{% for c in sorted %}
  {% assign rank = forloop.index %}
  {% if c >= rank %}{% assign h_index = rank %}{% endif %}
{% endfor %}

{% assign i10 = 0 %}
{% for c in citation_counts %}{% if c >= 10 %}{% assign i10 = i10 | plus: 1 %}{% endif %}{% endfor %}

<section aria-label="Academic citation statistics" class="academic-stats my-4">
  <dl class="row text-center m-0">
    <div class="col-4">
      <dt class="stat-number">{{ total_citations }}</dt>
      <dd class="stat-label">Citations</dd>
    </div>
    <div class="col-4">
      <dt class="stat-number">{{ h_index }}</dt>
      <dd class="stat-label">h-index</dd>
    </div>
    <div class="col-4">
      <dt class="stat-number">{{ i10 }}</dt>
      <dd class="stat-label">i10-index</dd>
    </div>
  </dl>
</section>
<div class="text-center mb-4">
  {% if site.data.socials.orcid_id %}
    <a href="https://orcid.org/{{ site.data.socials.orcid_id }}" target="_blank" rel="noopener">
      <i class="ai ai-orcid" aria-hidden="true"></i> ORCID
    </a> ·
  {% endif %}
  <a href="https://scholar.google.com/citations?user={{ site.data.socials.scholar_userid }}" target="_blank" rel="noopener">
    <i class="ai ai-google-scholar" aria-hidden="true"></i> Google Scholar
  </a>
</div>