<div class="col">
  <article class="card h-100 hoverable" style="position: relative;">
    {% if project.img %}
      {% capture project_img_alt %}Thumbnail image for the {{ project.title }} project{% endcapture %}
      {%
        include figure.liquid
        loading="eager"
        path=project.img
        sizes = "250px"
        alt=project_img_alt
        class="card-img-top"
      %}
    {% endif %}
    <div class="card-body">
      <h2 class="card-title">
        <a
          class="stretched-link"
          href="{% if project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}"
        >
          {{ project.title }}
        </a>
      </h2>
      <p class="card-text">{{ project.description }}</p>
      <div class="row ml-1 mr-1 p-0">
        {% if project.github or project.pdf or project.video %}
          <div class="d-flex align-items-center" style="position: relative; z-index: 2;">
            {% if project.github %}
              <div class="github-icon">
                <div class="icon" data-toggle="tooltip" title="Code repository">
                  <a href="{{ project.github }}" aria-label="View the code repository for {{ project.title }}">
                    <i class="fa-brands fa-github gh-icon" aria-hidden="true"></i>
                  </a>
                </div>
                {% if project.github_stars %}
                  <span class="stars" data-toggle="tooltip" title="GitHub stars">
                    <i class="fa-solid fa-star" aria-hidden="true"></i>
                    <span id="{{ project.github_stars }}-stars"></span>
                  </span>
                {% endif %}
              </div>
            {% endif %}
            {% if project.pdf %}
              <div class="pdf-icon">
                <div class="icon" data-toggle="tooltip" title="Project PDF">
                  <a
                    href="{{ '/assets/pdf/' | append: project.pdf | relative_url }}"
                    target="_blank"
                    rel="noopener"
                    aria-label="Open the PDF for {{ project.title }} in a new tab"
                  >
                    <i class="fa-solid fa-file-pdf" aria-hidden="true"></i>
                  </a>
                </div>
              </div>
            {% endif %}
            {% if project.video %}
              <div class="video-icon">
                <div class="icon" data-toggle="tooltip" title="Demo video">
                  <a
                    href="{{ project.video }}"
                    target="_blank"
                    rel="noopener"
                    aria-label="Watch the demo video for {{ project.title }} in a new tab"
                  >
                    <i class="fa-solid fa-circle-play" aria-hidden="true"></i>
                  </a>
                </div>
              </div>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </article>
</div>
